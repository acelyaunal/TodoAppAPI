{
  "Database": {
    "ConnectionString": "Data Source=todoapp.db",
    "ApplyMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": [
      "https://localhost:5173",
      "http://localhost:5173",
      "https://localhost:3000",
      "http://localhost:3000"
    ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "PermitLimit": 300,
    "QueueLimit": 10,
    "WindowSeconds": 60
  },
  "Security": {
    "MaxRequestBodySizeBytes": 1048576
  },
  "Swagger": {
    "Enabled": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1"
}
