{
  "Database": {
    "ConnectionString": "Data Source=todoapp.db",
    "ApplyMigrationsOnStartup": false
  },
  "Jwt": {
    "Issuer": "TodoAppAPI",
    "Audience": "TodoAppAPI.Client",
    "ExpirationMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://app.todoapp.example.com"
    ],
    "AllowCredentials": true
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "QueueLimit": 0,
    "WindowSeconds": 60
  },
  "Security": {
    "MaxRequestBodySizeBytes": 1048576
  },
  "Swagger": {
    "Enabled": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "api.todoapp.example.com"
}
